{
  "name": "relay",
  "private": true,
  "version": "1.2.0",
  "description": "Offline-first field service management platform",
  "author": "RELAY Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev -- --no-open\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:stable": "vite build --mode stable && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "vite": "^5.4.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "electron-updater": "^6.8.9",
    "jsdom": "^29.0.2"
  },
  "build": {
    "appId": "com.relay.dispatch",
    "productName": "RELAY Dispatch",
    "publish": [
      {
        "provider": "github",
        "owner": "berneyiscool-debug",
        "repo": "RELAY-Dispatch"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "RELAY Dispatch"
    }
  }
}
